// Sap_plm clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace sap_plm {

    entity Part {
        id: string @unique
        partNumber: string
        name: string
        revision: string
        material: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity BOM {
        id: string @unique
        parentPartId: string
        childPartId: string
        quantity: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity ChangeOrder {
        id: string @unique
        partId: string
        number: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity WorkOrder {
        id: string @unique
        partId: string
        quantity: integer
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Robot {
        id: string @unique
        model: string
        cellId: string
        status: string
        payloadKg: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Program {
        id: string @unique
        robotId: string
        name: string
        cycleTimeMs: integer
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
